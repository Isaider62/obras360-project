    "@obras360-project/auth": "workspace:*",
    "@obras360-project/db": "workspace:*",
    "@obras360-project/env": "workspace:*",
    "@orpc/openapi": "catalog:",
    "@orpc/server": "catalog:",
    "@orpc/zod": "catalog:",
    "@sinclair/typebox": "^0.34.49",
    "ai": "catalog:",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "elysia": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@obras360-project/config": "workspace:*",
    "@types/bun": "catalog:",
    "tsdown": "^0.21.9",
    "typescript": "^6"
  }
